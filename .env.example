# NavStation 环境变量示例
# 复制此文件为 .env 并填入实际值
# 注意：.env 已被 .gitignore 忽略，不会提交到 Git

# ── 必填 ──────────────────────────────────────────────────────────────────────
# JWT 签名密钥，至少 32 位随机字符串
# 生成方法：openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── 可选（百度地图/天气功能） ─────────────────────────────────────────────────
BAIDU_MAP_AK=
BAIDU_WEATHER_AK=

# 天气数据缓存时间（分钟）
WEATHER_CACHE_TTL_MINUTES=30
